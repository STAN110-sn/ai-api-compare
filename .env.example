# Models format: "id:DisplayName:inputCostPer1M:outputCostPer1M:reasoning[=low|medium|high]"
#   - All fields after the id are optional and may be empty
#   - Costs are in USD per 1,000,000 tokens
#   - "reasoning" enables the reasoning_effort dropdown for that model
#   - "reasoning=high" (or low/medium) also pre-selects that level by default
#   - "thinking-toggle" instead shows a Reasoning On/Off switch that sends
#     chat_template_kwargs.enable_thinking=false (ai& Qwen/Gemma)
# Examples:
#   gpt-4o:GPT-4o                           (display name only)
#   gpt-4o:GPT-4o:2.5:10                    (with input/output cost)
#   o4-mini:o4 mini:1.1:4.4:reasoning       (cost + reasoning_effort, default Off)
#   o4-mini:o4 mini:1.1:4.4:reasoning=high  (also default the dropdown to High)
#   qwen/qwen3.6-27b:Qwen3.6-27B:0:0:thinking-toggle  (Reasoning On/Off switch)

# Provider A Configuration
PROVIDER_A_NAME=OpenAI
PROVIDER_A_API_KEY=sk-your-openai-api-key
PROVIDER_A_BASE_URL=https://api.openai.com/v1
PROVIDER_A_MODELS=gpt-4o:GPT-4o:2.5:10,gpt-4o-mini:GPT-4o mini:0.15:0.6,o4-mini:o4 mini:1.1:4.4:reasoning

# Provider B Configuration
PROVIDER_B_NAME=Anthropic
PROVIDER_B_API_KEY=sk-ant-your-anthropic-api-key
PROVIDER_B_BASE_URL=https://api.anthropic.com/v1
PROVIDER_B_MODELS=claude-opus-4-7:Claude Opus 4.7:15:75,claude-sonnet-4-6:Claude Sonnet 4.6:3:15,claude-haiku-4-5:Claude Haiku 4.5:1:5

# Optional: Provider C
# PROVIDER_C_NAME=Azure OpenAI
# PROVIDER_C_API_KEY=your-azure-api-key
# PROVIDER_C_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# PROVIDER_C_MODELS=gpt-4:GPT-4:30:60,gpt-4-turbo:GPT-4 Turbo:10:30

# Optional: Provider D
# PROVIDER_D_NAME=Local LLM
# PROVIDER_D_API_KEY=your-local-api-key
# PROVIDER_D_BASE_URL=http://localhost:11434/v1
# PROVIDER_D_MODELS=llama2:Llama 2,mistral:Mistral,codellama:Code Llama
